---
const skillsData = [
  {
    category: "Desenvolvimento Frontend",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>`,
    skills: [
      { name: "Javascript (ES6+)", level: 90 },
      { name: "HTML5", level: 95 },
      { name: "CSS3 / Custom Styling", level: 90 },
      { name: "Astro Framework", level: 80 }
    ]
  },
  {
    category: "Backend & Ciência de Dados",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>`,
    skills: [
      { name: "Node.js", level: 80 },
      { name: "Python", level: 85 },
      { name: "Pandas (Data manipulation)", level: 85 },
      { name: "SQL (PostgreSQL/MySQL)", level: 80 }
    ]
  },
  {
    category: "Design de Produto & Analytics",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M8 14s1.5 2 4 2 4-2 4-2"></path><line x1="9" y1="9" x2="9.01" y2="9"></line><line x1="15" y1="9" x2="15.01" y2="9"></line></svg>`,
    skills: [
      { name: "UX / UI (Figma & Protótipos)", level: 85 },
      { name: "Design Responsivo", level: 90 },
      { name: "Power BI (Dashboards)", level: 80 },
      { name: "Arquitetura de Informação", level: 75 }
    ]
  }
];
---

<section id="skills" class="skills section">
  <div class="container">
    <h2 class="section-title">Habilidades</h2>
    <p class="skills-subtitle">As ferramentas e linguagens que utilizo no meu dia a dia para criar soluções de ponta a ponta.</p>
    
    <div class="grid-3 skills-grid">
      {skillsData.map(category => (
        <div class="skills-card glass-panel">
          <div class="skills-header">
            <div class="skills-icon" set:html={category.icon}></div>
            <h3>{category.category}</h3>
          </div>
          
          <div class="skills-list">
            {category.skills.map(skill => (
              <div class="skill-item">
                <div class="skill-info">
                  <span class="skill-name">{skill.name}</span>
                  <span class="skill-percentage">{skill.level}%</span>
                </div>
                <div class="skill-bar-bg">
                  <div class="skill-bar-fill" style={`width: ${skill.level}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills {
    background-color: var(--bg-primary);
  }

  .skills-subtitle {
    text-align: center;
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-top: -2.5rem;
    margin-bottom: 4rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .skills-card {
    padding: 2rem 1.75rem;
  }

  .skills-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1rem;
  }

  .skills-icon {
    width: 48px;
    height: 48px;
    background: var(--gradient-primary);
    color: var(--text-light);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px var(--shadow-glow);
  }

  .skills-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-main);
  }

  .skills-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .skill-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skill-info {
    display: flex;
    justify-content: space-between;
    font-size: 0.95rem;
    font-weight: 500;
  }

  .skill-name {
    color: var(--text-main);
  }

  .skill-percentage {
    color: var(--accent-rose);
    font-weight: 600;
  }

  .skill-bar-bg {
    width: 100%;
    height: 8px;
    background-color: rgba(255, 183, 197, 0.15);
    border-radius: var(--radius-full);
    overflow: hidden;
    position: relative;
  }

  .skill-bar-fill {
    height: 100%;
    background: var(--gradient-primary);
    border-radius: var(--radius-full);
    transition: width 1.5s cubic-bezier(0.1, 0.8, 0.2, 1);
  }

  /* Hover glow effect for the cards */
  .skills-card:hover .skill-bar-fill {
    opacity: 0.95;
    box-shadow: 0 0 8px var(--primary-pink);
  }
</style>
