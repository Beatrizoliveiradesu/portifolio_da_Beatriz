---
const tags = [
  "Developer", "Technology", "Javascript", "UX / UI", 
  "Power BI", "SQL", "HTML", "CSS", "Nodejs", "Python", "Pandas"
];
---

<section class="hero section">
  <div class="container hero-container grid-2 fade-in">
    <div class="hero-content">
      <div class="location-badge">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="location-icon">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
        <span>Florianópolis, Santa Catarina, Brasil</span>
      </div>
      
      <h1 class="hero-title">
        Olá, eu sou a <br/>
        <span class="gradient-text">Beatriz Oliveira</span>
      </h1>
      
      <p class="hero-description">
        Criando soluções inovadoras através da tecnologia, combinando design intuitivo de interfaces (UX/UI), análise de dados robusta e desenvolvimento de software completo.
      </p>

      <div class="tags-container">
        {tags.map(tag => (
          <span class="tag-badge">{tag}</span>
        ))}
      </div>

      <div class="hero-actions">
        <a href="#projects" class="btn btn-primary">
          Ver Projetos
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
        <a href="#contact" class="btn btn-secondary">Entrar em contato</a>
      </div>
    </div>

    <div class="hero-image-wrapper">
      <div class="avatar-glow"></div>
      <div class="avatar-frame">
        <img src="/avatar.png" alt="Foto de Beatriz Oliveira" class="avatar-img" />
      </div>
      
      <!-- Tiny floating decorative cards for UX/UI, Python, SQL -->
      <div class="floating-card card-ux glass-panel">
        <span class="emoji">🎨</span>
        <div>
          <h4>UX/UI</h4>
          <p>Design Limpo</p>
        </div>
      </div>
      <div class="floating-card card-code glass-panel">
        <span class="emoji">💻</span>
        <div>
          <h4>Developer</h4>
          <p>Javascript & Python</p>
        </div>
      </div>
      <div class="floating-card card-data glass-panel">
        <span class="emoji">📈</span>
        <div>
          <h4>Data Science</h4>
          <p>Power BI & Pandas</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 100px;
    padding-bottom: 40px;
    background: radial-gradient(circle at 10% 20%, rgba(255, 183, 197, 0.15) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(255, 163, 184, 0.1) 0%, transparent 50%);
  }

  .hero-container {
    align-items: center;
  }

  .location-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
    box-shadow: 0 4px 10px var(--shadow-color);
    margin-bottom: 1.5rem;
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
  }

  .location-icon {
    width: 14px;
    height: 14px;
    color: var(--accent-rose);
  }

  .hero-title {
    font-size: 3.5rem;
    line-height: 1.15;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 2.8rem;
    }
  }

  .hero-description {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    max-width: 540px;
  }

  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2.5rem;
    max-width: 580px;
  }

  .tag-badge {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgba(255, 183, 197, 0.12);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: all var(--transition-fast);
    cursor: default;
  }

  .tag-badge:hover {
    background: var(--gradient-primary);
    color: var(--text-light);
    border-color: transparent;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--shadow-glow);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  /* Right Side: Avatar & Floating Components */
  .hero-image-wrapper {
    position: relative;
    width: 100%;
    max-width: 440px;
    margin: 3rem auto 0;
    aspect-ratio: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero-image-wrapper {
      margin-top: 0;
    }
  }

  .avatar-glow {
    position: absolute;
    width: 80%;
    height: 80%;
    background: var(--gradient-primary);
    border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%;
    filter: blur(25px);
    opacity: 0.45;
    animation: blobMorph 10s ease-in-out infinite alternate;
  }

  .avatar-frame {
    position: relative;
    width: 78%;
    height: 78%;
    border-radius: 40% 60% 60% 40% / 50% 40% 60% 50%;
    overflow: hidden;
    border: 4px solid var(--bg-card);
    box-shadow: 0 15px 35px var(--shadow-color);
    background: var(--bg-secondary);
    animation: blobMorph 10s ease-in-out infinite alternate;
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.05);
    transition: transform var(--transition-slow);
  }

  .hero-image-wrapper:hover .avatar-img {
    transform: scale(1.1);
  }

  /* Floating UI Cards */
  .floating-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1.2rem;
    border-radius: var(--radius-md);
    z-index: 10;
    max-width: 200px;
  }

  .floating-card h4 {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-main);
  }

  .floating-card p {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .floating-card .emoji {
    font-size: 1.25rem;
  }

  .card-ux {
    top: 10%;
    left: -10%;
    animation: float 5s ease-in-out infinite;
  }

  .card-code {
    bottom: 12%;
    right: -10%;
    animation: float 6s ease-in-out infinite 1s;
  }

  .card-data {
    bottom: -5%;
    left: 10%;
    animation: float 7s ease-in-out infinite 0.5s;
  }

  /* Animations */
  @keyframes blobMorph {
    0% { border-radius: 42% 58% 70% 30% / 45% 45% 55% 55%; }
    50% { border-radius: 70% 30% 52% 48% / 60% 40% 60% 40%; }
    100% { border-radius: 42% 58% 70% 30% / 45% 45% 55% 55%; }
  }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }
</style>
